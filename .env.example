# API Configuration
VITE_API_URL=http://localhost:3000/api

# Data Source Configuration
# Set to 'true' to use localStorage mock data, 'false' to use real backend API
VITE_USE_MOCK_DATA=false

# API Timeout in milliseconds
VITE_API_TIMEOUT=15000

# Auth Configuration
# Keys used for localStorage
VITE_AUTH_TOKEN_KEY=hr_pro_access_token
VITE_AUTH_REFRESH_TOKEN_KEY=hr_pro_refresh_token
